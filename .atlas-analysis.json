  "keyFeatures": [
    "Modern Angular with Signals, Zoneless, and Standalone components",
    "PWA-ready with offline support and service worker integration",
    "Supabase authentication with OAuth, email/password, and magic links",
    "RBAC (Role-Based Access Control) system with audit logging",
    "Material Design theming with light/dark mode support",
    "Internationalization (i18n) with Transloco and RTL support",
    "Production-ready services for analytics, storage, and alerts",
    "Strict TypeScript, ESLint, and Prettier configurations",
    "Automated release management with conventional commits",
    "Responsive layout with safe-area styles for mobile devices"
  ],
  "publicApiSurface": [
    "UserService - Authentication and user management",
    "ProfileService - Profile data and avatar management",
    "SettingsService - App settings and preferences",
    "AnalyticsService - Google Analytics integration",
    "AlertService - Toast notifications and alerts",
    "StorageService - Browser storage abstraction",
    "LoggerService - Application logging",
    "ProgressBarService - Global progress indicator",
    "ServiceWorkerService - PWA update notifications",
    "signedInGuard - Route guard for authenticated users",
    "signedOutGuard - Route guard for unauthenticated users",
    "unsavedChangesGuard - Route guard for unsaved changes",
    "AnalyticsDirective - Track user interactions",
    "progressBarInterceptor - HTTP request progress tracking",
    "SUPABASE_CLIENT - Supabase client injection token",
    "PageComponent - Reusable page wrapper with SEO",
    "ToolbarComponent - Main navigation toolbar",
    "SidenavComponent - Responsive side navigation",
    "FooterComponent - Application footer"
  ]
}
